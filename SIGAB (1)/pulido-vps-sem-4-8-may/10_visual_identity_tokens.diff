From a000000000000000000000000000000000000010 Mon Sep 17 00:00:00 2001
From: claude <claude@sandbox>
Date: Tue, 5 May 2026 13:45:00 +0000
Subject: [PATCH 5/8] style(identity): introduce SIGAB v2 tokens (Montserrat,
 Open Sans, cobalt #1B4F72, teal #2E86AB)

Capa de identidad oficial SIGAB v2. NO elimina los tokens previos
(Lexend/Inter/indigo) — coexisten para permitir migración incremental por
componente. Los tokens v1 quedan marcados como `@deprecated` y se removerán
después del demo del viernes.

Aplicar miércoles 6-may. SOLO tocar CSS / tailwind.config.
NO tocar backend, NO endpoints.
---
 sigab-frontend/index.html             |  4 ++
 sigab-frontend/src/index.css          | 75 ++++++++++++++++++++++++++-
 sigab-frontend/tailwind.config.js     | 35 +++++++++++++
 3 files changed, 113 insertions(+), 1 deletion(-)

diff --git a/sigab-frontend/index.html b/sigab-frontend/index.html
--- a/sigab-frontend/index.html
+++ b/sigab-frontend/index.html
@@ -5,6 +5,10 @@
     <link rel="icon" type="image/png" href="/imss_logo.png" />
     <meta name="viewport" content="width=device-width, initial-scale=1.0" />
     <title>SIGAB — HGR No. 1</title>
+    <!-- SIGAB v2 identity (miércoles 6-may): tipografías oficiales -->
+    <link rel="preconnect" href="https://fonts.googleapis.com" />
+    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
+    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
   </head>
   <body>
     <div id="root"></div>
diff --git a/sigab-frontend/src/index.css b/sigab-frontend/src/index.css
--- a/sigab-frontend/src/index.css
+++ b/sigab-frontend/src/index.css
@@ -3,7 +3,8 @@
 @tailwind utilities;

 /* ── Tipografía global ── */
+/* @deprecated v1 — se mantiene durante la migración miércoles 6-may.
+   Después del demo viernes 8-may eliminar y dejar sólo Open Sans. */
 body {
   font-family: 'Lexend', 'Inter', system-ui, -apple-system, sans-serif;
   -webkit-font-smoothing: antialiased;
@@ -11,6 +12,8 @@ body {

 /* ── Variables CSS — Design tokens de SIGAB ── */
 :root {
+  /* ─────────────  v1 (deprecado a partir del 6-may) ───────────── */
   --color-primary:     #4F46E5;
   --color-secondary:   #6366F1;
   --color-accent:      #818CF8;
@@ -27,6 +30,77 @@ body {
   --z-modal-nested: 60;
   --z-confirm:      70;
   --z-toast:        80;
+
+  /* ─────────────  SIGAB v2 — identidad oficial ─────────────
+     Cobalt + teal sobre superficie clara. Activar por componente
+     usando las clases `sigab-v2-*` y el namespace `cobalt-` / `teal-`.
+     No reemplazar las vars v1 hasta que TODOS los componentes migren. */
+  --sigab-cobalt-50:   #EAF2F8;
+  --sigab-cobalt-100:  #D4E5F0;
+  --sigab-cobalt-300:  #6FA8C8;
+  --sigab-cobalt-500:  #2E72A6;
+  --sigab-cobalt-600:  #235D8C;
+  --sigab-cobalt-700:  #1B4F72; /* primario oficial */
+  --sigab-cobalt-800:  #143E5A;
+  --sigab-cobalt-900:  #0E2D43;
+
+  --sigab-teal-50:     #E8F4F8;
+  --sigab-teal-300:    #7AB5C8;
+  --sigab-teal-500:    #2E86AB; /* acento oficial */
+  --sigab-teal-700:    #1F5D77;
+
+  /* Semánticos (mantener WCAG AA contra fondo blanco/cobalt-50) */
+  --sigab-success:     #1E8449;
+  --sigab-warning:     #B7791F;
+  --sigab-danger:      #B0341C;
+  --sigab-info:        var(--sigab-teal-500);
+
+  /* Superficies modo claro */
+  --sigab-bg:          #F5F8FB;
+  --sigab-surface:     #FFFFFF;
+  --sigab-surface-alt: #EAF2F8;
+  --sigab-border:      #D4E5F0;
+  --sigab-text:        #0E2D43;
+  --sigab-text-muted:  #4A6275;
+
+  /* Tipografía oficial */
+  --sigab-font-heading: 'Montserrat', system-ui, sans-serif;
+  --sigab-font-body:    'Open Sans', system-ui, sans-serif;
+
+  /* Radios y elevaciones homologadas */
+  --sigab-radius-sm:   6px;
+  --sigab-radius-md:   10px;
+  --sigab-radius-lg:   16px;
+  --sigab-shadow-sm:   0 1px 2px rgba(14,45,67,0.06);
+  --sigab-shadow-md:   0 4px 12px rgba(14,45,67,0.10);
+  --sigab-shadow-lg:   0 12px 32px rgba(14,45,67,0.14);
+
+  /* Espaciado de cards/modales (homologado) */
+  --sigab-pad-card:    24px;
+  --sigab-pad-modal:   28px;
+
+  /* Focus accesible cobalt */
+  --sigab-focus-ring:  0 0 0 3px rgba(46,134,171,0.45);
+}
+
+/* Activador de tema v2: añadir <html data-sigab-theme="v2"> o agregar
+   la clase `sigab-v2` al root del componente para usar la paleta nueva.
+   Esta separación permite migrar página por página y comparar A/B. */
+html[data-sigab-theme="v2"], .sigab-v2 {
+  background: var(--sigab-bg);
+  color: var(--sigab-text);
+  font-family: var(--sigab-font-body);
+}
+html[data-sigab-theme="v2"] h1,
+html[data-sigab-theme="v2"] h2,
+html[data-sigab-theme="v2"] h3,
+.sigab-v2 h1, .sigab-v2 h2, .sigab-v2 h3 {
+  font-family: var(--sigab-font-heading);
+  color: var(--sigab-cobalt-700);
+  font-weight: 600;
+  letter-spacing: -0.01em;
 }

 /* ── Focus ring global — accesibilidad ── */
diff --git a/sigab-frontend/tailwind.config.js b/sigab-frontend/tailwind.config.js
--- a/sigab-frontend/tailwind.config.js
+++ b/sigab-frontend/tailwind.config.js
@@ -10,7 +10,15 @@ export default {
   ],
   theme: {
     extend: {
+      // ── Identidad oficial SIGAB v2 (miércoles 6-may) ──
+      // Coexiste con el tema v1 (indigo). Activar v2 por componente con
+      // la clase `sigab-v2` o el atributo `data-sigab-theme="v2"` en raíz.
+      // Migración prevista: miércoles 6 → conversión incremental,
+      // viernes 8 (post-demo) → remover v1.
       screens: {
         'xs': '320px',
         '3xl': '1920px',  // 24" Full HD
         '4xl': '2560px',  // 27" 1440p / 2K
@@ -19,6 +27,8 @@ export default {
       fontFamily: {
         sans:  ['Lexend', 'Inter', 'system-ui', '-apple-system', 'sans-serif'],
         mono:  ['JetBrains Mono', 'Courier New', 'monospace'],
+        sigabHead: ['Montserrat', 'system-ui', 'sans-serif'],
+        sigabBody: ['"Open Sans"', 'system-ui', 'sans-serif'],
       },
       colors: {
         medical: {
@@ -36,6 +46,31 @@ export default {
           accent:    '#818CF8',
           glow:      'rgba(79,70,229,0.15)',
         },
+        // Paleta oficial SIGAB v2
+        cobalt: {
+          50:  '#EAF2F8',
+          100: '#D4E5F0',
+          300: '#6FA8C8',
+          500: '#2E72A6',
+          600: '#235D8C',
+          700: '#1B4F72', // primario
+          800: '#143E5A',
+          900: '#0E2D43',
+        },
+        teal2: {
+          50:  '#E8F4F8',
+          300: '#7AB5C8',
+          500: '#2E86AB', // acento
+          700: '#1F5D77',
+        },
+        sigabSemantic: {
+          success: '#1E8449',
+          warning: '#B7791F',
+          danger:  '#B0341C',
+        },
       },
       backgroundImage: {
         'sigab-gradient': 'linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%)',
--
2.34.1
